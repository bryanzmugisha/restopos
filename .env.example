# ── Database ──
# Local SQLite (development)
DATABASE_URL="file:./dev.db"

# Cloud PostgreSQL (production / multi-outlet sync)
# DATABASE_URL="postgresql://user:password@host:5432/restopos?schema=public"

# ── NextAuth ──
NEXTAUTH_SECRET="CHANGE_THIS_TO_A_RANDOM_32_CHAR_STRING"
NEXTAUTH_URL="http://localhost:3000"

# ── App ──
NEXT_PUBLIC_APP_NAME="RestoPOS"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_CURRENCY="UGX"
NEXT_PUBLIC_LOCALE="en-UG"

# ── Socket.io ──
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# ── Cloud sync (optional) ──
CLOUD_SYNC_ENABLED="false"
CLOUD_SYNC_URL=""
CLOUD_SYNC_KEY=""
